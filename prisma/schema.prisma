generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Establishment {
  id                String             @id @default(uuid())
  name              String
  siret             String             @unique
  address           String
  zipCode           String
  city              String
  country           String             @default("FR")
  vatNumber         String?
  phone             String?
  email             String?
  contactFirstName  String?
  contactLastName   String?
  logo              String?
  currency          String             @default("EUR")
  timezone          String             @default("Europe/Paris")
  licenseKey        String?
  licenseExpiresAt  DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  groupId           String?
  campaigns         Campaign[]
  categories        Category[]
  closures          Closure[]
  customers         Customer[]
  group             Group?             @relation(fields: [groupId], references: [id])
  loyaltyProgram    LoyaltyProgram?
  menus             Menu[]
  payModes          PaymentMode[]
  products          Product[]
  reservationConfig ReservationConfig?
  reservations      Reservation[]
  stockMoves        StockMovement[]
  tables            Table[]
  tickets           Ticket[]
  tvaRates          TvaRate[]
  users             User[]
  peripherals       Peripheral[]
  royaltyConfigs    RoyaltyConfig[]
  royaltyInvoices   RoyaltyInvoice[]
  purchaseOrders    PurchaseOrder[]

  @@map("establishments")
}

model User {
  id              String        @id @default(uuid())
  establishmentId String
  name            String
  initial         String
  role            UserRole      @default(WAITER)
  pin             String
  email           String?
  active          Boolean       @default(true)
  lastLoginAt     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  auditLogs       AuditLog[]
  sessions        Session[]
  tickets         Ticket[]
  establishment   Establishment @relation(fields: [establishmentId], references: [id])

  @@unique([establishmentId, email])
  @@map("users")
}

model Session {
  id        String    @id @default(uuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  createdAt DateTime  @default(now())
  revokedAt DateTime?
  user      User      @relation(fields: [userId], references: [id])

  @@map("sessions")
}

model TvaRate {
  id              String        @id @default(uuid())
  establishmentId String
  rate            Decimal       @db.Decimal(5, 2)
  label           String
  active          Boolean       @default(true)
  createdAt       DateTime      @default(now())
  products        Product[]
  ticketLines     TicketLine[]
  establishment   Establishment @relation(fields: [establishmentId], references: [id])

  @@unique([establishmentId, rate])
  @@map("tva_rates")
}

model Category {
  id              String        @id @default(uuid())
  establishmentId String
  label           String
  icon            String        @default("🍽️")
  color           String        @default("#4f7bff")
  img             String?
  sortOrder       Int           @default(0)
  type            CategoryType  @default(PRODUCT)
  active          Boolean       @default(true)
  kioskEnabled    Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  establishment   Establishment @relation(fields: [establishmentId], references: [id])
  products        Product[]

  @@map("categories")
}

enum CategoryType {
  PRODUCT
  ACCOMPANIMENT
  MENU
}

model Product {
  id              String          @id @default(uuid())
  establishmentId String
  categoryId      String
  tvaRateId       String
  name            String
  description     String?
  price           Decimal         @db.Decimal(10, 2)
  emoji           String          @default("🍽️")
  color           String          @default("#4f7bff")
  img             String?         @db.Text
  allergens       String[]        @default([])
  trEligible      Boolean         @default(false)
  type            ProductType     @default(SINGLE)
  barcode         String?
  stockEnabled    Boolean         @default(false)
  stockQty        Decimal?        @db.Decimal(10, 3)
  stockAlert      Decimal?        @db.Decimal(10, 3)
  active          Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  menuChoices             MenuChoice[]
  accompaniments          ProductAccompaniment[] @relation("ProductMainItem")
  usedAsAccompaniment     ProductAccompaniment[] @relation("ProductAsAccompaniment")
  category                Category        @relation(fields: [categoryId], references: [id])
  establishment           Establishment   @relation(fields: [establishmentId], references: [id])
  tvaRate                 TvaRate         @relation(fields: [tvaRateId], references: [id])
  stockMovements          StockMovement[]
  ticketLines             TicketLine[]

  @@map("products")
}

model Menu {
  id              String        @id @default(uuid())
  establishmentId String
  name            String
  description     String?
  emoji           String        @default("🍱")
  color           String        @default("#f472b6")
  img             String?
  basePrice       Decimal       @db.Decimal(10, 2)
  tva             Decimal       @db.Decimal(5, 2)
  menuType        MenuType      @default(MENU)
  trEligible      Boolean       @default(false)
  active          Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  steps           MenuStep[]
  establishment   Establishment @relation(fields: [establishmentId], references: [id])
  ticketLines     TicketLine[]

  @@map("menus")
}

model ProductAccompaniment {
  id              String              @id @default(uuid())
  productId       String
  accompanimentId String
  type            AccompanimentType   @default(ACCOMPANIMENT)
  label           String?
  priceExtra      Decimal             @default(0) @db.Decimal(10, 2)
  required        Boolean             @default(false)
  sortOrder       Int                 @default(0)
  product         Product             @relation("ProductMainItem", fields: [productId], references: [id])
  accompaniment   Product             @relation("ProductAsAccompaniment", fields: [accompanimentId], references: [id])

  @@unique([productId, accompanimentId, type])
  @@map("product_accompaniments")
}

enum AccompanimentType {
  ACCOMPANIMENT  // Accompagnement inclus (caisse + kiosk)
  SUPPLEMENT     // Supplément payant (caisse + kiosk)
  SUGGESTION     // Suggestion affichée uniquement sur le kiosk
}

model MenuStep {
  id        String       @id @default(uuid())
  menuId    String
  label     String
  icon      String       @default("🍽️")
  required  Boolean      @default(true)
  minChoice Int          @default(1)
  maxChoice Int          @default(1)
  sortOrder Int          @default(0)
  choices   MenuChoice[]
  menu      Menu         @relation(fields: [menuId], references: [id], onDelete: Cascade)

  @@map("menu_steps")
}

model MenuChoice {
  id         String   @id @default(uuid())
  stepId     String
  productId  String
  label      String
  priceExtra Decimal  @default(0) @db.Decimal(10, 2)
  sortOrder  Int      @default(0)
  product    Product  @relation(fields: [productId], references: [id])
  step       MenuStep @relation(fields: [stepId], references: [id], onDelete: Cascade)

  @@map("menu_choices")
}

model Table {
  id              String        @id @default(uuid())
  establishmentId String
  label           String
  section         String?       @default("Salle principale")
  covers          Int           @default(0)
  status          TableStatus   @default(FREE)
  posX            Int           @default(0)
  posY            Int           @default(0)
  emoji           String?       @default("🪑")
  active          Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  reservations    Reservation[]
  establishment   Establishment @relation(fields: [establishmentId], references: [id])
  tickets         Ticket[]

  @@map("tables")
}

model PaymentMode {
  id              String        @id @default(uuid())
  establishmentId String
  label           String
  icon            String        @default("💳")
  trAllowed       Boolean       @default(false)
  active          Boolean       @default(true)
  sortOrder       Int           @default(0)
  createdAt       DateTime      @default(now())
  establishment   Establishment @relation(fields: [establishmentId], references: [id])
  payments        Payment[]

  @@map("payment_modes")
}

model Ticket {
  id              String        @id @default(uuid())
  establishmentId String
  userId          String?
  tableId         String?
  customerId      String?
  number          Int
  orderMode       OrderMode     @default(DINE_IN)
  status          TicketStatus  @default(OPEN)
  covers          Int           @default(1)
  totalHt         Decimal       @default(0) @db.Decimal(10, 2)
  totalTva        Decimal       @default(0) @db.Decimal(10, 2)
  totalTtc        Decimal       @default(0) @db.Decimal(10, 2)
  discountType    String?
  discountValue   Decimal?      @db.Decimal(10, 2)
  discountAmount  Decimal       @default(0) @db.Decimal(10, 2)
  finalAmount     Decimal       @default(0) @db.Decimal(10, 2)
  hash            String?
  prevHash        String?
  signedAt        DateTime?
  cancelledAt     DateTime?
  cancelReason    String?
  cancelledById   String?
  parentTicketId  String?
  note            String?
  source          TicketSource  @default(CASHIER)
  externalId      String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  payments        Payment[]
  lines           TicketLine[]
  tvaBreakdown    TicketTva[]
  customer        Customer?     @relation(fields: [customerId], references: [id])
  establishment   Establishment @relation(fields: [establishmentId], references: [id])
  table           Table?        @relation(fields: [tableId], references: [id])
  user            User?         @relation(fields: [userId], references: [id])

  @@map("tickets")
}

model TicketLine {
  id              String   @id @default(uuid())
  ticketId        String
  productId       String?
  menuId          String?
  tvaRateId       String
  label           String
  qty             Decimal  @db.Decimal(10, 3)
  unitPriceHt     Decimal  @db.Decimal(10, 4)
  unitPriceTtc    Decimal  @db.Decimal(10, 2)
  tvaRate         Decimal  @db.Decimal(5, 2)
  totalHt         Decimal  @db.Decimal(10, 2)
  totalTva        Decimal  @db.Decimal(10, 2)
  totalTtc        Decimal  @db.Decimal(10, 2)
  note            String?
  trEligible      Boolean  @default(false)
  menuComposition Json?
  createdAt       DateTime @default(now())
  menu            Menu?    @relation(fields: [menuId], references: [id])
  product         Product? @relation(fields: [productId], references: [id])
  ticket          Ticket   @relation(fields: [ticketId], references: [id])
  tvaRateRef      TvaRate  @relation(fields: [tvaRateId], references: [id])

  @@map("ticket_lines")
}

model TicketTva {
  id       String  @id @default(uuid())
  ticketId String
  rate     Decimal @db.Decimal(5, 2)
  baseHt   Decimal @db.Decimal(10, 2)
  tvaAmt   Decimal @db.Decimal(10, 2)
  totalTtc Decimal @db.Decimal(10, 2)
  ticket   Ticket  @relation(fields: [ticketId], references: [id])

  @@map("ticket_tva")
}

model Payment {
  id            String      @id @default(uuid())
  ticketId      String
  paymentModeId String
  amount        Decimal     @db.Decimal(10, 2)
  cashGiven     Decimal?    @db.Decimal(10, 2)
  cashChange    Decimal?    @db.Decimal(10, 2)
  reference     String?
  createdAt     DateTime    @default(now())
  paymentMode   PaymentMode @relation(fields: [paymentModeId], references: [id])
  ticket        Ticket      @relation(fields: [ticketId], references: [id])

  @@map("payments")
}

model Closure {
  id              String        @id @default(uuid())
  establishmentId String
  type            ClosureType
  periodStart     DateTime
  periodEnd       DateTime
  ticketCount     Int
  cancelCount     Int           @default(0)
  totalHt         Decimal       @db.Decimal(12, 2)
  totalTva        Decimal       @db.Decimal(12, 2)
  totalTtc        Decimal       @db.Decimal(12, 2)
  hash            String
  prevHash        String?
  signedAt        DateTime      @default(now())
  userId          String
  softwareVersion String        @default("2.0.0")
  tvaBreakdown      Json
  payBreakdown      Json
  categoryBreakdown Json?
  establishment     Establishment @relation(fields: [establishmentId], references: [id])

  @@map("closures")
}

model StockMovement {
  id              String        @id @default(uuid())
  establishmentId String
  productId       String
  type            StockMoveType
  qty             Decimal       @db.Decimal(10, 3)
  reason          String?
  reference       String?
  userId          String?
  createdAt       DateTime      @default(now())
  establishment   Establishment @relation(fields: [establishmentId], references: [id])
  product         Product       @relation(fields: [productId], references: [id])

  @@map("stock_movements")
}

model AuditLog {
  id              String   @id @default(uuid())
  establishmentId String
  userId          String?
  action          String
  entity          String
  entityId        String?
  before          Json?
  after           Json?
  ip              String?
  userAgent       String?
  createdAt       DateTime @default(now())
  user            User?    @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

model DeliveryIntegration {
  id              String           @id @default(uuid())
  establishmentId String
  platform        DeliveryPlatform
  apiKey          String?
  webhookSecret   String?
  restaurantId    String?
  active          Boolean          @default(false)
  lastSyncAt      DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@unique([establishmentId, platform])
  @@map("delivery_integrations")
}

model Customer {
  id               String               @id @default(uuid())
  establishmentId  String
  firstName        String?
  lastName         String?
  email            String?
  phone            String?
  birthDate        DateTime?
  loyaltyCardId    String?              @unique
  loyaltyPoints    Int                  @default(0)
  loyaltyLevel     LoyaltyLevel         @default(BRONZE)
  totalSpent       Decimal              @default(0) @db.Decimal(12, 2)
  visitCount       Int                  @default(0)
  lastVisitAt      DateTime?
  consentMarketing Boolean              @default(false)
  consentAnalytics Boolean              @default(false)
  consentDate      DateTime?
  consentIp        String?
  deletedAt        DateTime?
  anonymizedAt     DateTime?
  preferredTable   String?
  allergies        String[]
  notes            String?
  address          String?
  tags             String[]
  source           CustomerSource       @default(CASHIER)
  externalId       String?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  campaignLogs     CampaignLog[]
  rewards          CustomerReward[]
  tickets          Ticket[]
  establishment    Establishment        @relation(fields: [establishmentId], references: [id])
  transactions     LoyaltyTransaction[]
  reservations     Reservation[]

  @@unique([establishmentId, email])
  @@unique([establishmentId, phone])
  @@index([establishmentId, loyaltyLevel])
  @@index([establishmentId, lastVisitAt])
  @@map("customers")
}

model LoyaltyProgram {
  id                 String          @id @default(uuid())
  establishmentId    String          @unique
  name               String          @default("Programme Fidélité")
  active             Boolean         @default(true)
  pointsPerEuro      Decimal         @default(1) @db.Decimal(5, 2)
  minPurchase        Decimal         @default(0) @db.Decimal(10, 2)
  pointsValue        Decimal         @default(0.01) @db.Decimal(8, 4)
  minRedeem          Int             @default(100)
  silverThreshold    Int             @default(500)
  goldThreshold      Int             @default(1500)
  platinumThreshold  Int             @default(5000)
  silverMultiplier   Decimal         @default(1.25) @db.Decimal(4, 2)
  goldMultiplier     Decimal         @default(1.5) @db.Decimal(4, 2)
  platinumMultiplier Decimal         @default(2.0) @db.Decimal(4, 2)
  birthdayBonus      Int             @default(200)
  pointsExpiryDays   Int?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  establishment      Establishment   @relation(fields: [establishmentId], references: [id])
  rewards            LoyaltyReward[]

  @@map("loyalty_programs")
}

model LoyaltyReward {
  id              String           @id @default(uuid())
  programId       String
  name            String
  description     String?
  emoji           String           @default("🎁")
  type            RewardType
  value           Decimal          @db.Decimal(10, 2)
  pointsCost      Int
  minLevel        LoyaltyLevel     @default(BRONZE)
  maxPerMonth     Int?
  active          Boolean          @default(true)
  validFrom       DateTime?
  validUntil      DateTime?
  createdAt       DateTime         @default(now())
  customerRewards CustomerReward[]
  program         LoyaltyProgram   @relation(fields: [programId], references: [id])

  @@map("loyalty_rewards")
}

model LoyaltyTransaction {
  id            String        @id @default(uuid())
  customerId    String
  ticketId      String?
  type          LoyaltyTxType
  points        Int
  balanceBefore Int
  balanceAfter  Int
  description   String?
  expiresAt     DateTime?
  createdAt     DateTime      @default(now())
  customer      Customer      @relation(fields: [customerId], references: [id])

  @@index([customerId, createdAt])
  @@map("loyalty_transactions")
}

model CustomerReward {
  id             String        @id @default(uuid())
  customerId     String
  rewardId       String
  status         RewardStatus  @default(PENDING)
  code           String        @unique
  usedAt         DateTime?
  usedOnTicketId String?
  expiresAt      DateTime?
  createdAt      DateTime      @default(now())
  customer       Customer      @relation(fields: [customerId], references: [id])
  reward         LoyaltyReward @relation(fields: [rewardId], references: [id])

  @@map("customer_rewards")
}

model Campaign {
  id               String         @id @default(uuid())
  establishmentId  String
  name             String
  type             CampaignType
  status           CampaignStatus @default(DRAFT)
  subject          String?
  bodyText         String
  bodyHtml         String?
  targetSegment    String         @default("all")
  targetConditions Json?
  estimatedReach   Int            @default(0)
  scheduledAt      DateTime?
  sentAt           DateTime?
  sentCount        Int            @default(0)
  openCount        Int            @default(0)
  clickCount       Int            @default(0)
  revenueGenerated Decimal        @default(0) @db.Decimal(12, 2)
  rgpdCompliant    Boolean        @default(true)
  unsubscribeLink  Boolean        @default(true)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  logs             CampaignLog[]
  establishment    Establishment  @relation(fields: [establishmentId], references: [id])

  @@map("campaigns")
}

model CampaignLog {
  id         String    @id @default(uuid())
  campaignId String
  customerId String
  status     String
  sentAt     DateTime  @default(now())
  openedAt   DateTime?
  clickedAt  DateTime?
  errorMsg   String?
  campaign   Campaign  @relation(fields: [campaignId], references: [id])
  customer   Customer  @relation(fields: [customerId], references: [id])

  @@map("campaign_logs")
}

model Reservation {
  id               String            @id @default(uuid())
  establishmentId  String
  customerId       String?
  firstName        String
  lastName         String
  phone            String
  email            String?
  covers           Int               @default(2)
  date             DateTime
  duration         Int               @default(90)
  tableId          String?
  status           ReservationStatus @default(CONFIRMED)
  confirmationSent Boolean           @default(false)
  reminderSent     Boolean           @default(false)
  notes            String?
  allergyNotes     String?
  occasion         String?
  source           String            @default("phone")
  externalId       String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  customer         Customer?         @relation(fields: [customerId], references: [id])
  establishment    Establishment     @relation(fields: [establishmentId], references: [id])
  table            Table?            @relation(fields: [tableId], references: [id])

  @@index([establishmentId, date])
  @@map("reservations")
}

model ReservationConfig {
  id                   String        @id @default(uuid())
  establishmentId      String        @unique
  acceptReservations   Boolean       @default(true)
  autoConfirm          Boolean       @default(true)
  sendConfirmation     Boolean       @default(true)
  slotInterval         Int           @default(30)
  minNoticeHours       Int           @default(2)
  maxAdvanceDays       Int?          @default(30)
  maxCoversPerSlot     Int           @default(20)
  defaultDuration      Int           @default(90)
  schedule             Json
  googleReserveEnabled Boolean       @default(false)
  googleReserveId      String?
  theForkEnabled       Boolean       @default(false)
  theForkId            String?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  establishment        Establishment @relation(fields: [establishmentId], references: [id])

  @@map("reservation_configs")
}

model Group {
  id                  String               @id @default(uuid())
  name                String
  slug                String               @unique
  logo                String?
  plan                String               @default("ENTERPRISE")
  currency            String               @default("EUR")
  timezone            String               @default("Europe/Paris")
  active              Boolean              @default(true)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  broadcastMessages   BroadcastMessage[]
  centralCategories   CentralCategory[]
  centralMenus        CentralMenu[]
  centralCatalog      CentralProduct[]
  consolidatedReports ConsolidatedReport[]
  establishments      Establishment[]
  groupUsers          GroupUser[]
  pricingRules        PricingRule[]
  royaltyConfigs      RoyaltyConfig[]
  royaltyInvoices     RoyaltyInvoice[]
  suppliers           Supplier[]

  @@map("groups")
}

model GroupUser {
  id        String    @id @default(uuid())
  groupId   String
  userId    String
  role      GroupRole @default(VIEWER)
  createdAt DateTime  @default(now())
  group     Group     @relation(fields: [groupId], references: [id])

  @@unique([groupId, userId])
  @@map("group_users")
}

model CentralCategory {
  id        String           @id @default(uuid())
  groupId   String
  label     String
  icon      String           @default("🍽️")
  color     String           @default("#4f7bff")
  sortOrder Int              @default(0)
  mandatory Boolean          @default(false)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  group     Group            @relation(fields: [groupId], references: [id])
  products  CentralProduct[]

  @@map("central_categories")
}

model CentralProduct {
  id                String                @id @default(uuid())
  groupId           String
  centralCategoryId String?
  name              String
  description       String?
  basePrice         Decimal               @db.Decimal(10, 2)
  emoji             String                @default("🍽️")
  img               String?
  tva               Decimal               @db.Decimal(5, 2)
  trEligible        Boolean               @default(false)
  barcode           String?
  isPropagated      Boolean               @default(true)
  priceOverridable  Boolean               @default(true)
  mandatory         Boolean               @default(false)
  active            Boolean               @default(true)
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  syncLogs          CatalogSyncLog[]
  centralCategory   CentralCategory?      @relation(fields: [centralCategoryId], references: [id])
  group             Group                 @relation(fields: [groupId], references: [id])
  siteOverrides     ProductSiteOverride[]

  @@map("central_products")
}

model CentralMenu {
  id           String   @id @default(uuid())
  groupId      String
  name         String
  description  String?
  emoji        String   @default("🍱")
  basePrice    Decimal  @db.Decimal(10, 2)
  isPropagated Boolean  @default(true)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  group        Group    @relation(fields: [groupId], references: [id])

  @@map("central_menus")
}

model ProductSiteOverride {
  id               String         @id @default(uuid())
  centralProductId String
  establishmentId  String
  localPrice       Decimal?       @db.Decimal(10, 2)
  localName        String?
  active           Boolean        @default(true)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  centralProduct   CentralProduct @relation(fields: [centralProductId], references: [id])

  @@unique([centralProductId, establishmentId])
  @@map("product_site_overrides")
}

model PricingRule {
  id         String          @id @default(uuid())
  groupId    String
  name       String
  type       PricingRuleType
  value      Decimal         @db.Decimal(8, 2)
  scope      String          @default("all")
  validFrom  DateTime?
  validUntil DateTime?
  active     Boolean         @default(true)
  createdAt  DateTime        @default(now())
  group      Group           @relation(fields: [groupId], references: [id])

  @@map("pricing_rules")
}

model CatalogSyncLog {
  id               String         @id @default(uuid())
  centralProductId String
  establishmentId  String
  action           SyncAction
  status           SyncStatus     @default(PENDING)
  error            String?
  triggeredBy      String?
  createdAt        DateTime       @default(now())
  resolvedAt       DateTime?
  centralProduct   CentralProduct @relation(fields: [centralProductId], references: [id])

  @@map("catalog_sync_logs")
}

model ConsolidatedReport {
  id              String     @id @default(uuid())
  groupId         String
  type            ReportType
  periodStart     DateTime
  periodEnd       DateTime
  totalTtc        Decimal    @db.Decimal(14, 2)
  totalHt         Decimal    @db.Decimal(14, 2)
  totalTva        Decimal    @db.Decimal(14, 2)
  ticketCount     Int
  byEstablishment Json
  tvaBreakdown    Json
  payBreakdown    Json
  topProducts       Json
  signature         String?
  previousSignature String?
  generatedAt       DateTime   @default(now())
  generatedBy       String?
  group             Group      @relation(fields: [groupId], references: [id])

  @@index([groupId, periodStart, periodEnd])
  @@index([groupId, type])
  @@map("consolidated_reports")
}

model BroadcastMessage {
  id          String      @id @default(uuid())
  groupId     String
  title       String
  body        String
  type        MessageType @default(INFO)
  targetSites Json?
  sentAt      DateTime    @default(now())
  expiresAt   DateTime?
  senderId    String
  group       Group       @relation(fields: [groupId], references: [id])

  @@map("broadcast_messages")
}

